# RabbitMQ Connection
RABBITMQ_HOST=rabbit
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Name of the queue to consume for "now playing" messages
RABBITMQ_QUEUE=now_playing

# Optionally, define a separate exchange for preview publishing
RABBITMQ_PREVIEW_EXCHANGE=rds_preview
RABBITMQ_PREVIEW_ROUTING_KEY=rds.preview

# RDS Encoder Connection
RDS_ENCODER_HOST=smartgen-mini
RDS_ENCODER_PORT=1024
